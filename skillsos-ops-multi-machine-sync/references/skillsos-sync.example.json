{
  "version": 1,
  "description": "Public-safe example manifest for one skill and one pack across local runtimes.",
  "state_root": "~/.local/state/skillsos-sync",
  "backup_root": "~/.local/state/skillsos-sync/backups",
  "items": [
    {
      "name": "skillsos-ops-multi-machine-sync",
      "kind": "pack",
      "family": "pack",
      "source_path": "skillsos-ops-multi-machine-sync",
      "target_name": "skillsos-ops-multi-machine-sync"
    }
  ],
  "hosts": {
    "codex-local": {
      "families": {
        "pack": {
          "install_target": "~/.codex/packs-public",
          "install_mode": "symlink"
        }
      }
    },
    "claude-local": {
      "families": {
        "pack": {
          "install_target": "~/.claude/packs-public",
          "install_mode": "symlink"
        }
      }
    },
    "agents-local": {
      "families": {
        "pack": {
          "install_target": "~/.agents/packs-public",
          "install_mode": "symlink"
        }
      }
    }
  }
}
